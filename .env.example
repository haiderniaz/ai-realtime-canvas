# Copy this file to .env (in packages/server) to enable the LLM path.
# Leaving LLM_PROVIDER / LLM_API_KEY blank makes the server use the
# deterministic fallback parser — the app still works with zero config.

# Provider: groq | openai | (empty = fallback only)
LLM_PROVIDER=

# API key for the chosen provider
LLM_API_KEY=

# Optional model override
# Groq default:  llama-3.3-70b-versatile
# OpenAI default: gpt-4o-mini
LLM_MODEL=

# Server port (default 4000)
PORT=4000

# Allowed CORS / socket origin for the web client (default 5173)
WEB_ORIGIN=http://localhost:5173
